#include "Light.hlsli"

//---------------------------------------------------------
// Wireframe_PS.hlsl - 线框模式像素着色器
// 
// 作用：输出固定白色，用于在实体立方体上叠加三角形边界线
// 这样白色边线就能在灰色立方体表面清晰显示
//---------------------------------------------------------
float4 PS(VertexOut pIn) : SV_Target
{
    // 固定输出白色（alpha=1.0 不透明）
    return float4(1.0f, 1.0f, 1.0f, 1.0f);
}
